# Cloudflare Turnstile Human Verification
# Free, hosted CAPTCHA — create a widget at https://dash.cloudflare.com (Turnstile)
# and set its hostname to your site. SITE_KEY is NEXT_PUBLIC_* = inlined at BUILD
# time (rebuild after changing); SECRET_KEY is read by the server at runtime.
# Public site key from the Turnstile dashboard
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-only secret key (do NOT prefix with NEXT_PUBLIC)
TURNSTILE_SECRET_KEY=

# Cloudflare R2 (file uploads, S3-compatible)
# Files upload straight from the browser to R2 via presigned PUT URLs (bypasses the
# 4.5MB function body limit); the server only signs URLs and never proxies file bytes.
# Create a bucket + an "Object Read & Write" API token (R2 > Manage R2 API Tokens),
# and set the bucket CORS to allow PUT from your site origin.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Email Notification (Resend)
# Server-only API key from https://resend.com/api-keys
RESEND_API_KEY=
# Recipient of inquiry notifications
CONTACT_EMAIL_TO=jay@biteerbags.com
# Sender address. For quick dev testing keep onboarding@resend.dev — note it can
# ONLY deliver to the Resend account owner's email. For production use an address
# on your verified domain (e.g. inquiry@betterbagsmm.com).
CONTACT_EMAIL_FROM=onboarding@resend.dev
# Sender for the auto-acknowledgment sent to the customer (verified-domain address;
# defaults to no-reply@betterbagsmm.com). Localized by the customer's submission locale.
CONTACT_ACK_FROM=no-reply@betterbagsmm.com

# Site base URL — SEO metadata / sitemap / Open Graph (NEXT_PUBLIC_, build-time)
NEXT_PUBLIC_BASE_URL=https://betterbagsmm.com

# Cal.com booking link for the Virtual Factory Tour page (NEXT_PUBLIC_, build-time)
# Format: "<cal-username>/<event-slug>", e.g. better-bags/virtual-factory-tour
# Setup guide: docs/CAL_COM_SETUP.md. When empty, the page shows a
# WhatsApp/email fallback card instead of the booking calendar.
NEXT_PUBLIC_CAL_LINK=

# Translation toolchain (Gemini) — used ONLY by local scripts/translate/*,
# never by the website build or runtime. Create a key at https://aistudio.google.com
GEMINI_API_KEY=
# Model used for translation / back-translation / cross-review
GEMINI_MODEL=gemini-3.1-pro-preview
