# mCaptcha Human Verification
# Self-hosted mCaptcha instance URL (no trailing slash), e.g. https://captcha.betterbagsmyanmar.com
NEXT_PUBLIC_MCAPTCHA_INSTANCE_URL=
# Public site key shown in the dashboard for this widget
NEXT_PUBLIC_MCAPTCHA_SITEKEY=
# Server-only account secret; do NOT prefix with NEXT_PUBLIC
MCAPTCHA_SECRET=

# Email Notification (Resend)
# Server-only API key from https://resend.com/api-keys
RESEND_API_KEY=
# Recipient of inquiry notifications
CONTACT_EMAIL_TO=jay@biteerbags.com
# Sender address. For quick dev testing keep onboarding@resend.dev — note it can
# ONLY deliver to the Resend account owner's email. For production use an address
# on your verified domain (e.g. inquiry@betterbagsmyanmar.com).
CONTACT_EMAIL_FROM=onboarding@resend.dev
